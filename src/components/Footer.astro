---
/**
 * Footer.astro — Site footer.
 * Props:
 *   variant: "full" | "minimal" — controls whether navigation columns are shown.
 */
interface Props {
  variant?: "full" | "minimal";
}

const { variant = "full" } = Astro.props;
---

<footer class="footer">
  <div class="container">
    {variant === "full" && (
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Colegio San Basilio</h4>
          <p style="opacity:0.7;font-size:0.9rem;">Colegio Pastoral Ortodoxo San Basilio — Diócesis de México, OCA.</p>
        </div>
        <div class="footer-col">
          <h4>Navegación</h4>
          <ul class="footer-links">
            <li><a href="/">Inicio</a></li>
            <li><a href="/administracion/">Administración</a></li>
            <li><a href="/contenido/">Contenido</a></li>
            <li><a href="/avisos/">Avisos</a></li>
            <li><a href="/alumnos/">Alumnos</a></li>
            <li><a href="/documentos-diocesis/">Documentos diócesis</a></li>
            <li><a href="/contacto/">Contacto</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <ul class="footer-links">
            <li><a href="/aviso-legal/">Aviso Legal</a></li>
            <li><a href="/politica-de-privacidad/">Política de Privacidad</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contacto</h4>
          <ul class="footer-links" style="opacity:0.7;font-size:0.9rem;">
            <li>+52 55 7903 1388</li>
            <li>cposb.oca@gmail.com</li>
          </ul>
        </div>
      </div>
    )}
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Colegio Pastoral Ortodoxo San Basilio. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
