---
import Base from "../layouts/Base.astro";
import BlockRenderer from "./blocks/BlockRenderer.astro";
import Lightbox from "./Lightbox.astro";

interface Props {
  page: {
    data: {
      title: string;
      description?: string;
      activePage?: string;
      sections: Array<Record<string, unknown>>;
    };
  };
}

const { page } = Astro.props;
// Lightbox loaded on every CMS page since any block can now hold zoomable images.
---

<Base
  title={`${page.data.title} | Colegio Pastoral Ortodoxo San Basilio`}
  description={page.data.description}
  activePage={page.data.activePage || ""}
>
  <main>
    {page.data.sections.map((section) => <BlockRenderer block={section} />)}
  </main>
  <Lightbox />
</Base>
