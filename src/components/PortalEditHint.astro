---
interface Props {
  canEdit: boolean;
  role: string | null;
}

const { canEdit, role } = Astro.props;
const show = canEdit && (role === "admin" || role === "profesor");
---

{show && (
  <div class="edit-note">
    <p>Tu rol permite editar esta seccion.</p>
    <a href="/admin/" class="btn btn-outline">Editar en CMS</a>
  </div>
)}

<style>
  .edit-note {
    margin: 1rem 0 2rem;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--color-accent);
    background: rgba(201, 170, 113, 0.1);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
  }
  .edit-note p { margin: 0; }
  @media (max-width: 768px) {
    .edit-note { flex-direction: column; align-items: flex-start; }
  }
</style>
