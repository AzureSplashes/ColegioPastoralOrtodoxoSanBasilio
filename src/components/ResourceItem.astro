---
/**
 * ResourceItem.astro — A downloadable PDF resource row.
 * Used on: textos-liturgicos, musica, curso-propedeutico, documentos-diocesis.
 * Props:
 *   title: string — document display name
 *   description: string — short context line
 *   href: string — path to the PDF in /documentos/
 */
interface Props {
  title: string;
  description?: string;
  href: string;
}

const { title, description = "", href } = Astro.props;
---

<div class="resource-item">
  <div class="resource-info">
    <h4>{title}</h4>
    {description && <p>{description}</p>}
  </div>
  <a href={href} class="download-btn" download>
    <i data-lucide="download"></i> PDF
  </a>
</div>
