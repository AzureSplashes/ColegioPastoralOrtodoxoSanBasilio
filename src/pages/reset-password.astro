---
import Base from "../layouts/Base.astro";
---

<Base
  title="Recuperar contrasena | Colegio Pastoral Ortodoxo San Basilio"
  description="Recuperacion de contrasena para el portal del Colegio Pastoral Ortodoxo San Basilio."
  activePage="alumnos"
>
  <main class="section">
    <div class="container">
      <div class="login-card">
        <h2 style="margin-bottom: 0.75rem;">Recuperar contrasena</h2>
        <p style="color: var(--color-text-light); margin-bottom: 1.5rem;" id="page-desc">
          Ingresa tu correo para recibir el enlace de recuperacion.
        </p>

        <form id="request-form">
          <div class="form-group">
            <label for="email">Correo electronico</label>
            <input type="email" id="email" name="email" required placeholder="tu-correo@ejemplo.com" />
          </div>
          <div id="request-msg" class="login-success" style="display:none;"></div>
          <div id="request-error" class="login-error" style="display:none;"></div>
          <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;" id="request-btn">
            Enviar enlace
          </button>
        </form>

        <form id="update-form" style="display:none; margin-top: 2rem;">
          <div class="form-group">
            <label for="password">Nueva contrasena</label>
            <input type="password" id="password" name="password" minlength="8" required placeholder="Minimo 8 caracteres" />
          </div>
          <div class="form-group">
            <label for="password2">Confirmar contrasena</label>
            <input type="password" id="password2" name="password2" minlength="8" required placeholder="Repite tu contrasena" />
          </div>
          <div id="update-msg" class="login-success" style="display:none;"></div>
          <div id="update-error" class="login-error" style="display:none;"></div>
          <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;" id="update-btn">
            Guardar nueva contrasena
          </button>
        </form>
      </div>
    </div>
  </main>
</Base>

<style>
  .login-card {
    max-width: 520px;
    margin: 4rem auto;
    background: var(--color-white);
    padding: 3rem;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
  }
  .form-group { margin-bottom: 1.25rem; text-align: left; }
  .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 500; font-size: 0.9rem; }
  .form-group input { width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-family: inherit; font-size: 1rem; }
  .form-group input:focus { outline: none; border-color: var(--color-primary); }
  .login-error { background: #fef2f2; color: #991b1b; padding: 0.75rem 1rem; border-radius: 4px; font-size: 0.9rem; margin-bottom: 1rem; }
  .login-success { background: #ecfdf3; color: #166534; padding: 0.75rem 1rem; border-radius: 4px; font-size: 0.9rem; margin-bottom: 1rem; }
</style>

<script is:inline>
  (async function () {
    const url = document.querySelector('meta[name="supabase-url"]')?.content;
    const key = document.querySelector('meta[name="supabase-anon-key"]')?.content;
    if (!url || !key) return;

    const { createClient } = await import("https://esm.sh/@supabase/supabase-js@2");
    const supabase = createClient(url, key);

    const requestForm = document.getElementById("request-form");
    const requestBtn = document.getElementById("request-btn");
    const requestMsg = document.getElementById("request-msg");
    const requestError = document.getElementById("request-error");

    const updateForm = document.getElementById("update-form");
    const updateBtn = document.getElementById("update-btn");
    const updateMsg = document.getElementById("update-msg");
    const updateError = document.getElementById("update-error");
    const pageDesc = document.getElementById("page-desc");

    const hash = window.location.hash || "";
    const query = new URLSearchParams(window.location.search);
    const hashParams = new URLSearchParams(hash.startsWith("#") ? hash.slice(1) : hash);
    const recoveryType = hashParams.get("type") || query.get("type");
    const hasRecoveryToken = hashParams.has("access_token") || hashParams.has("refresh_token") || query.has("token_hash");

    if (recoveryType === "recovery" || hasRecoveryToken) {
      requestForm.style.display = "none";
      updateForm.style.display = "block";
      pageDesc.textContent = "Define tu nueva contrasena para completar la recuperacion.";
    }

    requestForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      requestMsg.style.display = "none";
      requestError.style.display = "none";
      requestBtn.disabled = true;
      requestBtn.textContent = "Enviando...";

      const email = document.getElementById("email")?.value;
      const redirectTo = `${window.location.origin}/reset-password`;

      const { error } = await supabase.auth.resetPasswordForEmail(email, { redirectTo });

      if (error) {
        requestError.textContent = error.message || "No fue posible enviar el enlace.";
        requestError.style.display = "block";
        requestBtn.disabled = false;
        requestBtn.textContent = "Enviar enlace";
        return;
      }

      requestMsg.textContent = "Te enviamos un enlace de recuperacion. Revisa tu correo.";
      requestMsg.style.display = "block";
      requestBtn.disabled = false;
      requestBtn.textContent = "Enviar enlace";
    });

    updateForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      updateMsg.style.display = "none";
      updateError.style.display = "none";

      const pass1 = document.getElementById("password")?.value || "";
      const pass2 = document.getElementById("password2")?.value || "";

      if (pass1.length < 8) {
        updateError.textContent = "La contrasena debe tener al menos 8 caracteres.";
        updateError.style.display = "block";
        return;
      }

      if (pass1 !== pass2) {
        updateError.textContent = "Las contrasenas no coinciden.";
        updateError.style.display = "block";
        return;
      }

      updateBtn.disabled = true;
      updateBtn.textContent = "Guardando...";

      const { error } = await supabase.auth.updateUser({ password: pass1 });
      if (error) {
        updateError.textContent = error.message || "No se pudo actualizar la contrasena.";
        updateError.style.display = "block";
        updateBtn.disabled = false;
        updateBtn.textContent = "Guardar nueva contrasena";
        return;
      }

      updateMsg.textContent = "Contrasena actualizada. Ahora puedes iniciar sesion.";
      updateMsg.style.display = "block";
      updateBtn.disabled = false;
      updateBtn.textContent = "Guardar nueva contrasena";
      setTimeout(() => {
        window.location.href = "/alumnos/";
      }, 1500);
    });
  })();
</script>
