---
export const prerender = false;

import Portal from "../../../layouts/Portal.astro";
import PortalEditHint from "../../../components/PortalEditHint.astro";
import { getCollection } from "astro:content";
import { getPortalPageConfig } from "../../../lib/portal";
import { marked } from "marked";

const clases = (await getCollection("clases")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const pageConfig = await getPortalPageConfig("clases");
const role = (Astro.locals.role as string | null) ?? null;
---

<Portal title="Clases | Portal de Alumnos" portalPage="clases">
  <main class="section">
    <div class="container">
      <div class="section-header">
        <h1 class="section-title">{pageConfig.title}</h1>
        <div class="section-desc" set:html={marked.parse(pageConfig.description)} />
      </div>

      <PortalEditHint canEdit={pageConfig.professorEditable} role={role} />

      {clases.length === 0 ? (
        <div class="empty-state">
          <i data-lucide="book-open"></i>
          <p>No hay clases publicadas por el momento.</p>
        </div>
      ) : (
        <div class="content-list">
          {clases.map((clase) => (
            <a href={`/alumnos/clases/${clase.id}/`} class="content-card">
              <div class="content-card-body">
                <time class="content-date">
                  {new Date(clase.data.date).toLocaleDateString("es-MX", {
                    year: "numeric", month: "long", day: "numeric",
                  })}
                </time>
                <h3 class="content-title">{clase.data.title}</h3>
                <p class="content-desc">{clase.data.description}</p>
              </div>
              <i data-lucide="chevron-right" class="content-arrow"></i>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
</Portal>

<style>
  .empty-state { text-align: center; padding: 4rem 2rem; color: var(--color-text-light); }
  .empty-state i { width: 48px; height: 48px; margin-bottom: 1rem; color: var(--color-accent); }
  .content-list { margin-top: 2rem; }
  .content-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-white);
    padding: 1.5rem 2rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    border-left: 4px solid var(--color-accent);
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .content-card:hover { transform: translateX(5px); box-shadow: var(--shadow-md); }
  .content-date { display: block; font-size: 0.8rem; color: var(--color-accent); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.25rem; }
  .content-title { font-size: 1.2rem; color: var(--color-primary); margin-bottom: 0.25rem; }
  .content-desc { font-size: 0.9rem; color: var(--color-text-light); }
  .content-arrow { color: var(--color-text-light); flex-shrink: 0; }
</style>
