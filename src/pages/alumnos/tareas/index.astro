---
export const prerender = false;

import Portal from "../../../layouts/Portal.astro";
import PortalEditHint from "../../../components/PortalEditHint.astro";
import { getCollection } from "astro:content";
import { getPortalPageConfig } from "../../../lib/portal";
import { marked } from "marked";

const tareas = (await getCollection("tareas")).sort(
  (a, b) => new Date(b.data.dueDate).getTime() - new Date(a.data.dueDate).getTime()
);

const pageConfig = await getPortalPageConfig("tareas");
const role = (Astro.locals.role as string | null) ?? null;
---

<Portal title="Tareas | Portal de Alumnos" portalPage="tareas">
  <main class="section">
    <div class="container">
      <div class="section-header">
        <h1 class="section-title">{pageConfig.title}</h1>
        <div class="section-desc" set:html={marked.parse(pageConfig.description)} />
      </div>

      <PortalEditHint canEdit={pageConfig.professorEditable} role={role} />

      {tareas.length === 0 ? (
        <div class="empty-state">
          <i data-lucide="clipboard-list"></i>
          <p>No hay tareas publicadas por el momento.</p>
        </div>
      ) : (
        <div class="content-list">
          {tareas.map((tarea) => {
            const isPast = new Date(tarea.data.dueDate) < new Date();
            return (
              <a href={`/alumnos/tareas/${tarea.id}/`} class:list={["content-card", { past: isPast }]}>
                <div class="content-card-body">
                  <div class="tarea-meta">
                    <time class="content-date">
                      Entrega: {new Date(tarea.data.dueDate).toLocaleDateString("es-MX", {
                        year: "numeric", month: "long", day: "numeric",
                      })}
                    </time>
                    {isPast && <span class="badge-past">Fecha pasada</span>}
                  </div>
                  <h3 class="content-title">{tarea.data.title}</h3>
                  <p class="content-desc">{tarea.data.description}</p>
                  {tarea.data.link && (
                    <span class="link-indicator">
                      <i data-lucide="external-link" style="width:14px;height:14px"></i> Enlace adjunto
                    </span>
                  )}
                </div>
                <i data-lucide="chevron-right" class="content-arrow"></i>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </main>
</Portal>

<style>
  .empty-state { text-align: center; padding: 4rem 2rem; color: var(--color-text-light); }
  .empty-state i { width: 48px; height: 48px; margin-bottom: 1rem; color: var(--color-accent); }
  .content-list { margin-top: 2rem; }
  .content-card {
    display: flex; justify-content: space-between; align-items: center;
    background: var(--color-white); padding: 1.5rem 2rem; border-radius: 8px;
    margin-bottom: 1rem; border-left: 4px solid var(--color-accent);
    box-shadow: var(--shadow-sm); transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none; color: inherit;
  }
  .content-card.past { border-left-color: #ccc; opacity: 0.7; }
  .content-card:hover { transform: translateX(5px); box-shadow: var(--shadow-md); }
  .tarea-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.25rem; }
  .content-date { font-size: 0.8rem; color: var(--color-accent); text-transform: uppercase; letter-spacing: 1px; }
  .badge-past { font-size: 0.7rem; background: #f3f4f6; color: #6b7280; padding: 0.15rem 0.5rem; border-radius: 10px; }
  .content-title { font-size: 1.2rem; color: var(--color-primary); margin-bottom: 0.25rem; }
  .content-desc { font-size: 0.9rem; color: var(--color-text-light); }
  .link-indicator { font-size: 0.8rem; color: var(--color-primary); margin-top: 0.5rem; display: inline-flex; align-items: center; gap: 0.3rem; }
  .content-arrow { color: var(--color-text-light); flex-shrink: 0; }
</style>
