---
/**
 * index.astro — Landing page (Inicio).
 * Sections: Hero, Features Bar, Institutional Grid, Orígenes.
 */
import Base from "../layouts/Base.astro";
---

<Base title="Colegio Pastoral Ortodoxo San Basilio" activePage="inicio">
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">Formación en la fe para servir a la Iglesia</h1>
          <p class="hero-subtitle">
            Formar sacerdotes en nuestra Fe Ortodoxa y Tradición Litúrgica,
            capaces de hacer misión y fomentar una adecuada pastoral entre el
            Pueblo de Dios.
          </p>
          <div class="hero-btns">
            <a href="/sede/" class="btn btn-primary">
              <i data-lucide="book-open"></i> Conócenos
            </a>
            <a
              href="https://wa.me/525636196242"
              target="_blank"
              class="btn btn-outline"
            >
              <i data-lucide="message-circle"></i> Calendario Académico
            </a>
          </div>
        </div>
      </div>
      <img
        src="/assets/img/logo.png"
        alt="Logo del Colegio San Basilio"
        class="hero-image-side"
      />
    </section>

    <!-- Features Bar -->
    <section class="features-bar">
      <div class="container">
        <div class="features-grid">
          <div class="feature-item">
            <div class="feature-icon"><i data-lucide="church"></i></div>
            <div class="feature-text">
              <h4>Formación Integral</h4>
              <p>Preparación teológica, litúrgica y pastoral para el servicio a la Iglesia Ortodoxa.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i data-lucide="cross"></i></div>
            <div class="feature-text">
              <h4>Fidelidad a la Tradición</h4>
              <p>Enseñanza fundamentada en la Sagrada Escritura, los Santos Padres y los Concilios Ecuménicos.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i data-lucide="library"></i></div>
            <div class="feature-text">
              <h4>Vida Litúrgica</h4>
              <p>Formación práctica en los oficios y servicios litúrgicos de la tradición ortodoxa.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon"><i data-lucide="users"></i></div>
            <div class="feature-text">
              <h4>Comunidad</h4>
              <p>Aprendizaje en comunidad bajo la guía de sacerdotes y profesores experimentados.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Institutional Identity Section -->
    <section
      class="section"
      id="institucional"
      style="background: linear-gradient(rgba(244, 242, 235, 0.85), rgba(244, 242, 235, 0.85)), url('/assets/img/institucional_bg.png'); background-size: cover; background-position: center; background-attachment: fixed;"
    >
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Nuestra Institución</h2>
          <p>Formando pastores en la Tradición y Fe Ortodoxa.</p>
        </div>
        <div class="institutional-grid">
          <a href="/sede/" class="institutional-block">
            <div class="institutional-content">
              <h3 class="institutional-title">Sede del Colegio</h3>
            </div>
          </a>
          <a href="/historia/" class="institutional-block">
            <div class="institutional-content">
              <h3 class="institutional-title">Historia</h3>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Orígenes Section -->
    <section class="section" id="origenes">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Orígenes del Colegio</h2>
        </div>
        <div style="max-width: 800px; margin: 0 auto; text-align: center;">
          <p style="font-size: 1.1rem; margin-bottom: 2rem;">
            El Colegio Pastoral de Ortodoxo San Basilio fue fundado en el año de
            1974 por su gracia Obispo José de bendita memoria, en el cual se
            formó la segunda generación de sacerdotes del ese entonces Exarcado
            de México. Se tuvo la destacada participación de Su Eminencia Antonio
            Chedraui como profesor del Colegio. Las actividades del Colegio
            concluyeron en ese tiempo en el año de 1983 tras el reposo en el
            Señor del Obispo José. Actualmente el Colegio ha sido rehabilitado
            por Su Eminencia Alejo en el año de 2021.
          </p>
          <a
            href="/documentos/DECRETO 005.pdf"
            class="btn"
            style="background-color: transparent; color: var(--color-primary); border: 2px solid var(--color-primary); margin-bottom: 3rem; display: inline-flex;"
            download
          >
            <i data-lucide="file-text"></i> DECRETO NÚMERO 005 REHABILITACIÓN DEL
            COLEGIO PASTORAL ORTODOXO SAN BASILIO
          </a>
          <img
            src="/assets/img/IMG_6385-901.jpg"
            alt="Fotografía histórica del Colegio Pastoral Ortodoxo San Basilio"
            style="margin: 0 auto; border-radius: 8px; box-shadow: var(--shadow-md); max-width: 100%; margin-bottom: 2rem;"
          />
        </div>
      </div>
    </section>
  </main>
</Base>
