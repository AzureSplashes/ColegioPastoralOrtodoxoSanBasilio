---
/**
 * alumnos/recursos/index.astro — Resources listing (protected).
 */
export const prerender = false;

import Portal from "../../../layouts/Portal.astro";
import { getCollection } from "astro:content";

const recursos = (await getCollection("recursos")).sort(
  (a, b) => a.data.title.localeCompare(b.data.title)
);

const categoryIcons: Record<string, string> = {
  Lectura: "book-open",
  Video: "play-circle",
  Documento: "file-text",
  Enlace: "external-link",
};
---

<Portal title="Recursos | Portal de Alumnos" portalPage="recursos">
  <main class="section">
    <div class="container">
      <div class="section-header">
        <h1 class="section-title">Recursos</h1>
        <p>Material de apoyo, lecturas y enlaces para el curso.</p>
      </div>

      {recursos.length === 0 ? (
        <div class="empty-state">
          <i data-lucide="folder-open"></i>
          <p>No hay recursos publicados por el momento.</p>
        </div>
      ) : (
        <div class="content-list">
          {recursos.map((recurso) => (
            <a href={`/alumnos/recursos/${recurso.id}/`} class="content-card">
              <div class="content-card-body">
                <span class="category-badge">
                  <i data-lucide={categoryIcons[recurso.data.category] || "file"} style="width:14px;height:14px"></i>
                  {recurso.data.category}
                </span>
                <h3 class="content-title">{recurso.data.title}</h3>
                <p class="content-desc">{recurso.data.description}</p>
              </div>
              <i data-lucide="chevron-right" class="content-arrow"></i>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
</Portal>

<style>
  .empty-state { text-align: center; padding: 4rem 2rem; color: var(--color-text-light); }
  .empty-state i { width: 48px; height: 48px; margin-bottom: 1rem; color: var(--color-accent); }
  .content-list { margin-top: 2rem; }
  .content-card {
    display: flex; justify-content: space-between; align-items: center;
    background: var(--color-white); padding: 1.5rem 2rem; border-radius: 8px;
    margin-bottom: 1rem; border-left: 4px solid var(--color-accent);
    box-shadow: var(--shadow-sm); transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none; color: inherit;
  }
  .content-card:hover { transform: translateX(5px); box-shadow: var(--shadow-md); }
  .category-badge {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;
    color: var(--color-accent); font-weight: 600; margin-bottom: 0.25rem;
  }
  .content-title { font-size: 1.2rem; color: var(--color-primary); margin-bottom: 0.25rem; }
  .content-desc { font-size: 0.9rem; color: var(--color-text-light); }
  .content-arrow { color: var(--color-text-light); flex-shrink: 0; }
</style>
